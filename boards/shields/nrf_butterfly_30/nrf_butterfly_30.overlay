// Unibody (non-split) 30-key board, single Seeeduino XIAO BLE.
//
// Electrical matrix is 5 sense lines (xiao_d 0-4) x 6 drive lines
// (xiao_d 5,10,6,9,7,8), 30 keys. Scanning is ACTIVE-LOW: each drive line is
// pulsed low while the sense lines are read through internal pull-ups (a
// pressed key reads low), matching this board's known-good Arduino firmware.
// The switch diodes conduct from the sense lines toward the drive lines, so
// the drive lines have to be the driven outputs -- in ZMK's kscan-gpio-matrix
// that is diode-direction = "col2row" (outputs = col-gpios = the drive lines,
// inputs = row-gpios = the sense lines). Note the active-low/pull-up polarity:
// xiao_split_60 wires its diodes the other way and scans active-high, so do not
// copy that shield's GPIO flags here.
//
// Each physical row of 10 keys is wired as a left half on one drive pin and a
// right half (mirrored) on the paired drive pin -- see the matrix-transform map
// below, which reads out in normal left-to-right, top-to-bottom physical order
// regardless of the underlying wiring.

#include <dt-bindings/zmk/matrix_transform.h>

#include "nrf_butterfly_30-layouts.dtsi"

/ {
    chosen {
        zmk,physical-layout = &default_layout;
        zmk,kscan = &kscan;
    };

    kscan: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";
        wakeup-source;

        col-gpios
            = <&xiao_d 5 GPIO_ACTIVE_LOW>
            , <&xiao_d 10 GPIO_ACTIVE_LOW>
            , <&xiao_d 6 GPIO_ACTIVE_LOW>
            , <&xiao_d 9 GPIO_ACTIVE_LOW>
            , <&xiao_d 7 GPIO_ACTIVE_LOW>
            , <&xiao_d 8 GPIO_ACTIVE_LOW>
            ;

        row-gpios
            = <&xiao_d 0 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            , <&xiao_d 1 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            , <&xiao_d 2 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            , <&xiao_d 3 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            , <&xiao_d 4 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            ;
    };

    default_transform: default_transform {
        compatible = "zmk,matrix-transform";
        columns = <6>;
        rows = <5>;

        map = <
            RC(0,0) RC(1,0) RC(2,0) RC(3,0) RC(4,0)    RC(4,1) RC(3,1) RC(2,1) RC(1,1) RC(0,1)
            RC(0,2) RC(1,2) RC(2,2) RC(3,2) RC(4,2)    RC(4,3) RC(3,3) RC(2,3) RC(1,3) RC(0,3)
            RC(0,4) RC(1,4) RC(2,4) RC(3,4) RC(4,4)    RC(4,5) RC(3,5) RC(2,5) RC(1,5) RC(0,5)
        >;
    };
};
